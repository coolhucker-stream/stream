{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Streaming": {
    "PlaybackBaseUrl": "http://localhost:8081/live",
    "RtmpBaseUrl": "rtmp://localhost:1935/live"
  },
  "Security": {
    "RequireHttps": false,
    "EnableCors": true,
    "AllowedOrigins": ["http://localhost:8080", "http://127.0.0.1:8080", "http://localhost:3000"]
  }
}
