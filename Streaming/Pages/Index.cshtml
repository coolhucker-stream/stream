@page
@model WatchModel
@{
    ViewData["Title"] = Model.Stream?.Title ?? "Watch Stream";
}

@if (Model.Stream == null)
{
    <div class="container text-center mt-5">
        <h2>Stream not found</h2>
        <p>This stream might have ended or doesn't exist.</p>
        <a href="/" class="btn btn-primary">Back to Home</a>
    </div>
}
else
{
    <div class="watch-container">
        <div class="video-section">
            <div class="video-player">
                <!-- Live Stream Player (HLS) -->
                <video id="streamPlayer" controls autoplay muted style="width: 100%; height: auto; display: none;">
                    Your browser does not support the video tag.
                </video>
                <div id="streamStatus" class="alert alert-info mt-2" style="display: none;">
                    <span id="statusMessage">Loading stream...</span>
                </div>
                <!-- Stream Offline -->
                @* <div class="alert alert-warning text-center p-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; border: none;">
                        <i class="fas fa-video-slash fa-3x mb-3"></i>
                        <h3>Stream Offline</h3>
                        <p class="mb-0">The streamer is not currently live. Check back later!</p>
                    </div> *@
            </div>

            <div class="stream-header">
                <div class="stream-main-info">
                    <div class="streamer-avatar-large" style="background-image: url('/images/avatar.jpg'); background-size: cover; background-position: center; background-repeat: no-repeat;">
                    </div>
                    <div>
                        <h1 class="stream-title-large">@Model.Stream.Title</h1>
                        <p class="streamer-name-large">@Model.Stream.Description</p>
                    </div>
                </div>
                <div class="stream-stats">
                    <span class="live-indicator" id="onlineStatus" style="display: none;">
                        <span class="pulse"></span>
                        LIVE
                    </span>
                    <span id="offlineStatus" class="badge bg-secondary">
                        OFFLINE
                    </span>
                    <span class="viewer-stat">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8zM1.173 8a13.133 13.133 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13.133 13.133 0 0 1 14.828 8c-.058.087-.122.183-.195.288-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5c-2.12 0-3.879-1.168-5.168-2.457A13.134 13.134 0 0 1 1.172 8z" />
                            <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5zM4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z" />
                        </svg>
                        <span class="player-viewer-stat">0 online</span>
                    </span>
                </div>
            </div>
        </div>

        <div class="chat-section">
            <div class="chat-header">
                <h3>Live Chat</h3>
                <span class="chat-viewer-count" id="viewerCount">0 online</span>
            </div>
            <div class="chat-messages" id="chatMessages">
                <!-- Chat messages will be added here dynamically -->
            </div>
            <div class="chat-input-container">
                <input type="text" id="chatInput" class="chat-input" placeholder="Send a message..." />
                <button class="chat-send-btn" id="chatSendBtn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M15.854.146a.5.5 0 0 1 .11.54l-5.819 14.547a.75.75 0 0 1-1.329.124l-3.178-4.995L.643 7.184a.75.75 0 0 1 .124-1.33L15.314.037a.5.5 0 0 1 .54.11ZM6.636 10.07l2.761 4.338L14.13 2.576 6.636 10.07Zm6.787-8.201L1.591 6.602l4.339 2.76 7.494-7.493Z" />
                    </svg>
                </button>
            </div>
        </div>
         </div>
    }

    @section Scripts {
        <!-- Watch page styles -->
        <link rel="stylesheet" href="~/css/watch.css" asp-append-version="true" />

        <!-- SignalR client library -->
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

        <!-- Watch page JavaScript - load first to initialize error handler -->
        <script>
            // Pass server-side data to JavaScript BEFORE loading hls.js
            window.streamUrl = '@Model.Stream?.StreamUrl';

            // Track hls.js loading state
            window.hlsLoadStartTime = Date.now();
            window.hlsLoaded = false;
        </script>

        <!-- Hls.js for HLS (.m3u8) playback -->
        <script src="https://cdn.jsdelivr.net/npm/hls.js@latest/dist/hls.min.js"
                onload="window.hlsLoaded = true; console.log('✅ hls.js loaded successfully in ' + (Date.now() - window.hlsLoadStartTime) + 'ms');"
                onerror="console.error('❌ Failed to load hls.js from CDN');">
        </script>

        <!-- Main watch page logic -->
        <script src="~/js/chat.js" asp-append-version="true"></script>
        <script src="~/js/player.js" asp-append-version="true"></script>
        <script src="~/js/signalr.js" asp-append-version="true"></script>
        <script src="~/js/watch.js" asp-append-version="true"></script>
    }