{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.HttpLogging": "Information"
    }
  },
  "AllowedHosts": "*",
  "Streaming": {
    "PlaybackBaseUrl": "https://footballteams.ru/live",
    "RtmpBaseUrl": "rtmp://footballteams.ru:1935/live"
  },
  "Security": {
    "RequireHttps": true,
    "EnableCors": true,
    "AllowedOrigins": ["https://footballteams.ru", "https://www.footballteams.ru"]
  },
  "Performance": {
    "EnableResponseCaching": true,
    "EnableOutputCaching": true,
    "EnableCompression": true
  }
}